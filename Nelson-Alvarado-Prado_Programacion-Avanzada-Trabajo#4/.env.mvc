# Environment Configuration for Vehicle MVC Application

# API Configuration
# Set the API base URL (should match where api-server.js or flask_app.py is running)
API_URL=http://localhost:5000/api

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True

# Server Configuration
PORT=8080
HOST=0.0.0.0

# Optional: Database Configuration (if using MySQL backend)
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=
# DB_NAME=car_park
# USE_DATABASE=false
