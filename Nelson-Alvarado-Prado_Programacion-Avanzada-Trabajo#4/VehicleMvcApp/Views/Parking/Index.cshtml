@using VehicleMvcApp.Models;
@model ParkingSearchViewModel

@{
    ViewData["Title"] = "Parking Lot Entry Viewer";
    var dataSourceColor = Model.DataSource == "Database" ? "#28a745" : "#007bff";
}

<div class="container-fluid mt-4">
    <!-- Header -->
    <div class="row mb-4">
        <div class="col-md-8">
            <h1>
                <i class="fas fa-parking"></i> Parking Lot Entry Viewer
            </h1>
            <p class="text-muted">View parking lot entries and billing information for vehicles</p>
        </div>
        <div class="col-md-4 text-end">
            <span class="badge" style="background-color: @dataSourceColor; font-size: 1rem; padding: 0.5rem 1rem;">
                <i class="fas fa-database"></i> Data Source: @Model.DataSource
            </span>
        </div>
    </div>

    <!-- Search Panel -->
    <div class="card mb-4 shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">
                <i class="fas fa-filter"></i> Filter by Vehicle Type
            </h5>
        </div>
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-6">
                    <label for="vehicleTypeSelect" class="form-label">
                        <strong>Vehicle Type:</strong>
                    </label>
                    <select id="vehicleTypeSelect" class="form-select form-select-lg">
                        <option value="">-- Select a vehicle type --</option>
                        <option value="sedan" @(Model.SelectedType == "sedan" ? "selected" : "")>🚗 Sedan</option>
                        <option value="4x4" @(Model.SelectedType == "4x4" ? "selected" : "")>🚙 4x4</option>
                        <option value="motorcycle" @(Model.SelectedType == "motorcycle" ? "selected" : "")>🏍️ Motorcycle</option>
                    </select>
                </div>
                <div class="col-md-6">
                    <button type="button" class="btn btn-primary btn-lg w-100" id="searchBtn">
                        <i class="fas fa-search"></i> Query Vehicles
                    </button>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(Model.Message) && Model.HasError)
            {
                <div class="alert alert-danger mt-3 mb-0">
                    <i class="fas fa-exclamation-circle"></i> @Model.Message
                </div>
            }
        </div>
    </div>

    <!-- Vehicles Grid -->
    @if (Model.MatchingVehicles != null && Model.MatchingVehicles.Count > 0)
    {
        <div class="row mb-4">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h4>
                        <i class="fas fa-list"></i> Matching Vehicles
                        <span class="badge bg-info ms-2">@Model.MatchingVehicles.Count found</span>
                    </h4>
                </div>

                <div class="row g-3">
                    @foreach (var vehicle in Model.MatchingVehicles)
                    {
                        <div class="col-md-6 col-lg-4">
                            <div class="card h-100 vehicle-card cursor-pointer" 
                                 onclick="selectVehicle(@vehicle.Id, '@vehicle.Make')" 
                                 style="cursor: pointer; transition: all 0.3s ease;">
                                <div class="card-header bg-light">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <h6 class="mb-1 fw-bold">@vehicle.Make @vehicle.Year</h6>
                                            <small class="text-muted">ID: @vehicle.Id</small>
                                        </div>
                                        <span class="badge bg-secondary">@vehicle.Type</span>
                                    </div>
                                </div>
                                <div class="card-body">
                                    <div class="row g-3">
                                        <div class="col-6">
                                            <small class="text-muted d-block">Color</small>
                                            <strong>@vehicle.Color</strong>
                                        </div>
                                        <div class="col-6">
                                            <small class="text-muted d-block">Year</small>
                                            <strong>@vehicle.Year</strong>
                                        </div>
                                    </div>
                                </div>
                                <div class="card-footer bg-light text-center">
                                    <small class="text-muted">Click to view parking entries</small>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
    else if (!string.IsNullOrEmpty(Model.SelectedType) && (Model.MatchingVehicles == null || Model.MatchingVehicles.Count == 0))
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> No vehicles found for type: <strong>@Model.SelectedType</strong>
        </div>
    }

    <!-- Parking Entries Panel -->
    @if (Model.SelectedVehicle != null && Model.ParkingEntries != null && Model.ParkingEntries.Count > 0)
    {
        <div class="card mt-4 shadow">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">
                    <i class="fas fa-history"></i> Parking History for @Model.SelectedVehicle.Make (@Model.SelectedVehicle.Year)
                </h5>
            </div>
            <div class="card-body p-0">
                <!-- Summary Stats -->
                <div class="row g-0 border-bottom">
                    <div class="col-md-4 p-3 border-end">
                        <div class="text-center">
                            <h6 class="text-muted mb-1">Total Entries</h6>
                            <h3 class="text-primary fw-bold">@Model.ParkingEntries.Count</h3>
                        </div>
                    </div>
                    <div class="col-md-4 p-3 border-end">
                        <div class="text-center">
                            <h6 class="text-muted mb-1">Currently Parked</h6>
                            <h3 class="text-warning fw-bold">@Model.ParkingEntries.Count(e => e.IsCurrentlyParked)</h3>
                        </div>
                    </div>
                    <div class="col-md-4 p-3">
                        <div class="text-center">
                            <h6 class="text-muted mb-1">Total Revenue</h6>
                            <h3 class="text-success fw-bold">${@Model.ParkingEntries.Sum(e => e.AmountDue):F2}</h3>
                        </div>
                    </div>
                </div>

                <!-- Entries Table -->
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Parking Lot</th>
                                <th>Entry Date/Time</th>
                                <th>Exit Date/Time</th>
                                <th class="text-end">Duration (min)</th>
                                <th class="text-end">Duration (hrs)</th>
                                <th class="text-end">Amount Due</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var entry in Model.ParkingEntries)
                            {
                                var isActive = entry.IsCurrentlyParked;
                                var rowClass = isActive ? "table-warning" : "";
                                
                                <tr class="@rowClass">
                                    <td>
                                        <strong>@entry.EntryNumber</strong>
                                    </td>
                                    <td>
                                        <div>
                                            <strong>@entry.ParkingLotName</strong><br />
                                            <small class="text-muted">@entry.ParkingLotProvince (ID: @entry.ParkingLotId)</small>
                                        </div>
                                    </td>
                                    <td>
                                        <small>@entry.EntryDateTimeFormatted</small>
                                    </td>
                                    <td>
                                        @if (entry.IsCurrentlyParked)
                                        {
                                            <span class="badge bg-warning">Still Parked</span>
                                        }
                                        else
                                        {
                                            <small>@entry.ExitDateTimeFormatted</small>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <strong>@entry.StayDurationMinutes</strong>
                                    </td>
                                    <td class="text-end">
                                        <strong>@entry.StayDurationHours</strong>
                                    </td>
                                    <td class="text-end">
                                        <strong class="@(entry.AmountDue > 0 ? "text-success" : "text-muted")">
                                            @if (entry.AmountDue > 0)
                                            {
                                                <span>${@entry.AmountDue:F2}</span>
                                            }
                                            else
                                            {
                                                <span>Pending</span>
                                            }
                                        </strong>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else if (Model.SelectedVehicle != null && (Model.ParkingEntries == null || Model.ParkingEntries.Count == 0))
    {
        <div class="alert alert-info mt-4">
            <i class="fas fa-info-circle"></i> 
            @if (!string.IsNullOrEmpty(Model.Message))
            {
                @Model.Message
            }
            else
            {
                <span>No parking entries found for this vehicle.</span>
            }
        </div>
    }
</div>

<style>
    .vehicle-card {
        border: 2px solid #ddd;
        transition: all 0.3s ease;
    }

    .vehicle-card:hover {
        border-color: #007bff;
        box-shadow: 0 4px 12px rgba(0, 123, 255, 0.25) !important;
        transform: translateY(-2px);
    }

    .table-hover tbody tr:hover {
        background-color: rgba(0, 123, 255, 0.05);
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        const searchBtn = document.getElementById('searchBtn');
        const typeSelect = document.getElementById('vehicleTypeSelect');

        searchBtn.addEventListener('click', function () {
            const selectedType = typeSelect.value;
            if (selectedType) {
                window.location.href = `/Parking/Index?vehicleType=${selectedType}`;
            } else {
                alert('Please select a vehicle type');
            }
        });

        // Allow Enter key in select
        typeSelect.addEventListener('keypress', function (e) {
            if (e.key === 'Enter') {
                searchBtn.click();
            }
        });
    });

    function selectVehicle(carId, vehicleName) {
        const vehicleTypeSelect = document.getElementById('vehicleTypeSelect').value;
        window.location.href = `/Parking/Index?vehicleType=${vehicleTypeSelect}&carId=${carId}`;
    }
</script>
