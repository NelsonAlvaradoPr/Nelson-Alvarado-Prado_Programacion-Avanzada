@using VehicleMvcApp.Models;
@model Vehicle

@{
    ViewData["Title"] = "Vehicle Details";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        :root {
            --primary: #2c3e50;
            --secondary: #3498db;
            --success: #27ae60;
            --danger: #e74c3c;
        }

        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
        }

        .navbar {
            background-color: var(--primary) !important;
        }

        .container-main {
            max-width: 900px;
            margin: 2rem auto;
            padding: 0 1rem;
        }

        .card {
            border: none;
            border-radius: 10px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

        .card-header {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: white;
            border-radius: 10px 10px 0 0 !important;
            padding: 1.5rem;
        }

        .detail-label {
            font-weight: 600;
            color: var(--primary);
            margin-bottom: 0.5rem;
        }

        .detail-value {
            font-size: 1.2rem;
            color: #2c3e50;
            margin-bottom: 1.5rem;
        }

        .btn {
            border-radius: 5px;
            font-weight: 500;
        }

        .btn-info {
            background: #16a085;
            border: none;
        }

        .btn-warning {
            background: #f39c12;
            border: none;
        }

        .btn-danger {
            background: var(--danger);
            border: none;
        }

        .color-preview {
            width: 60px;
            height: 60px;
            border-radius: 8px;
            border: 2px solid #ddd;
            margin-bottom: 1rem;
        }

        .badge {
            padding: 0.5rem 1rem;
            font-size: 0.95rem;
            font-weight: 500;
        }

        .data-source {
            background-color: #e7f3ff;
            color: #004085;
            padding: 0.75rem 1rem;
            border-radius: 5px;
            border-left: 4px solid #0066cc;
            margin-top: 1rem;
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">
                <i class="fas fa-car"></i> Vehicle Manager
            </a>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container-main">
        <div class="card">
            <div class="card-header">
                <h3><i class="fas fa-info-circle"></i> Vehicle Details - #@Model.Id</h3>
            </div>
            <div class="card-body p-4">
                <!-- Vehicle ID and Year -->
                <div class="row mb-4">
                    <div class="col-md-6">
                        <div class="detail-label">Vehicle ID</div>
                        <div class="detail-value">#@Model.Id</div>
                    </div>
                    <div class="col-md-6">
                        <div class="detail-label">Year</div>
                        <div class="detail-value">@Model.Year</div>
                    </div>
                </div>

                <!-- Color and Type -->
                <div class="row mb-4">
                    <div class="col-md-6">
                        <div class="detail-label">Color</div>
                        <div class="color-preview" style="background-color: @Model.Color.ToLower();"></div>
                        <div class="detail-value">@Model.Color</div>
                    </div>
                    <div class="col-md-6">
                        <div class="detail-label">Type</div>
                        <div class="detail-value">
                            <span class="badge" style="background-color: @(Model.Type == "sedan" ? "#dfe6e9" : Model.Type == "4x4" ? "#fab1a0" : "#74b9ff"); 
                                                       color: @(Model.Type == "sedan" ? "#2d3436" : Model.Type == "4x4" ? "#d63031" : "#0050b3");">
                                <i class="fas fa-car"></i> @Model.Type.ToUpper()
                            </span>
                        </div>
                    </div>
                </div>

                <!-- Make -->
                <div class="row mb-4">
                    <div class="col-md-12">
                        <div class="detail-label">Make</div>
                        <div class="detail-value">@Model.Make</div>
                    </div>
                </div>

                <!-- Data Source -->
                <div class="data-source">
                    <i class="@(ViewBag.DataSource.Contains("Database") ? "fas fa-database" : "fas fa-file-json")"></i>
                    <strong>Data Source:</strong> @ViewBag.DataSource
                </div>

                <hr class="my-4">

                <!-- Action Buttons -->
                <div class="d-flex gap-2 justify-content-between mt-4">
                    <a href="@Url.Action("Index", "Vehicles")" class="btn btn-secondary">
                        <i class="fas fa-arrow-left"></i> Back to List
                    </a>
                    <div>
                        <a href="@Url.Action("Edit", "Vehicles", new { id = Model.Id })" class="btn btn-warning">
                            <i class="fas fa-edit"></i> Edit
                        </a>
                        <a href="@Url.Action("Delete", "Vehicles", new { id = Model.Id })" class="btn btn-danger">
                            <i class="fas fa-trash"></i> Delete
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
