@using VehicleMvcApp.Models;
@model Vehicle

@{
    ViewData["Title"] = $"Edit Vehicle #{Model.Id}";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        :root {
            --primary: #2c3e50;
            --secondary: #3498db;
        }

        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
        }

        .navbar {
            background-color: var(--primary) !important;
        }

        .container-main {
            max-width: 700px;
            margin: 2rem auto;
            padding: 0 1rem;
        }

        .card {
            border: none;
            border-radius: 10px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

        .card-header {
            background: linear-gradient(135deg, var(--primary), var(--secondary));
            color: white;
            border-radius: 10px 10px 0 0 !important;
            padding: 1.5rem;
        }

        .form-label {
            font-weight: 500;
            color: var(--primary);
        }

        .form-control, .form-select {
            border-radius: 5px;
            border: 1px solid #ddd;
        }

        .form-control:focus, .form-select:focus {
            border-color: var(--secondary);
            box-shadow: 0 0 0 0.2rem rgba(52, 152, 219, 0.25);
        }

        .btn {
            border-radius: 5px;
            font-weight: 500;
        }

        .alert {
            border-radius: 8px;
            border: none;
        }

        .data-source {
            background-color: #e7f3ff;
            color: #004085;
            padding: 0.75rem 1rem;
            border-radius: 5px;
            border-left: 4px solid #0066cc;
            margin-bottom: 1rem;
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">
                <i class="fas fa-car"></i> Vehicle Manager
            </a>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container-main">
        <div class="card">
            <div class="card-header">
                <h3><i class="fas fa-edit"></i> Edit Vehicle #@Model.Id</h3>
            </div>
            <div class="card-body p-4">
                <!-- Data Source -->
                <div class="data-source">
                    <i class="@(ViewBag.DataSource.Contains("Database") ? "fas fa-database" : "fas fa-file-json")"></i>
                    <strong>Data Source:</strong> @ViewBag.DataSource
                </div>

                <form method="post">
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-3">
                        <label asp-for="Color" class="form-label">
                            <i class="fas fa-palette"></i> Color <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Color" class="form-control" required maxlength="50">
                        <span asp-validation-for="Color" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Year" class="form-label">
                            <i class="fas fa-calendar"></i> Year <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Year" type="number" class="form-control" min="1900" max="@ViewBag.CurrentYear" required>
                        <span asp-validation-for="Year" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Make" class="form-label">
                            <i class="fas fa-industry"></i> Make <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Make" class="form-control" required maxlength="100">
                        <span asp-validation-for="Make" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Type" class="form-label">
                            <i class="fas fa-car"></i> Type <span class="text-danger">*</span>
                        </label>
                        <select asp-for="Type" class="form-select" required>
                            <option value="">-- Select Vehicle Type --</option>
                            <option value="sedan" @(Model.Type == "sedan" ? "selected" : "")>🚗 Sedan</option>
                            <option value="4x4" @(Model.Type == "4x4" ? "selected" : "")>🚙 4x4</option>
                            <option value="motorcycle" @(Model.Type == "motorcycle" ? "selected" : "")>🏍️ Motorcycle</option>
                        </select>
                        <span asp-validation-for="Type" class="text-danger small"></span>
                    </div>

                    <div class="alert alert-info" role="alert">
                        <i class="fas fa-info-circle"></i>
                        <strong>Note:</strong> All fields marked with <span class="text-danger">*</span> are required.
                    </div>

                    <div class="d-flex gap-2 justify-content-between mt-4">
                        <a href="@Url.Action("Index", "Vehicles")" class="btn btn-secondary">
                            <i class="fas fa-times"></i> Cancel
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save"></i> Update Vehicle
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
