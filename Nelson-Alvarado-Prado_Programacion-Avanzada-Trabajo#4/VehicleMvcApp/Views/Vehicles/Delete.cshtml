@using VehicleMvcApp.Models;
@model Vehicle

@{
    ViewData["Title"] = $"Delete Vehicle #{Model.Id}";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <style>
        :root {
            --primary: #2c3e50;
            --secondary: #3498db;
            --danger: #e74c3c;
        }

        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
        }

        .navbar {
            background-color: var(--primary) !important;
        }

        .container-main {
            max-width: 700px;
            margin: 2rem auto;
            padding: 0 1rem;
        }

        .card {
            border: none;
            border-radius: 10px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

        .card-header {
            background: linear-gradient(135deg, var(--danger), #c0392b);
            color: white;
            border-radius: 10px 10px 0 0 !important;
            padding: 1.5rem;
        }

        .btn {
            border-radius: 5px;
            font-weight: 500;
        }

        .alert {
            border-radius: 8px;
            border: none;
        }

        .detail-section {
            background-color: #f8f9fa;
            padding: 1rem;
            border-radius: 5px;
            margin-bottom: 1rem;
        }

        .detail-label {
            font-weight: 600;
            color: var(--primary);
            margin-bottom: 0.3rem;
        }

        .detail-value {
            color: #2c3e50;
            font-size: 1.1rem;
        }

        .data-source {
            background-color: #e7f3ff;
            color: #004085;
            padding: 0.75rem 1rem;
            border-radius: 5px;
            border-left: 4px solid #0066cc;
            margin-bottom: 1rem;
        }
    </style>
</head>
<body>
    <!-- Navigation -->
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">
                <i class="fas fa-car"></i> Vehicle Manager
            </a>
        </div>
    </nav>

    <!-- Main Content -->
    <div class="container-main">
        <div class="card">
            <div class="card-header">
                <h3><i class="fas fa-trash"></i> Delete Vehicle #@Model.Id</h3>
            </div>
            <div class="card-body p-4">
                <!-- Data Source -->
                <div class="data-source">
                    <i class="@(ViewBag.DataSource.Contains("Database") ? "fas fa-database" : "fas fa-file-json")"></i>
                    <strong>Data Source:</strong> @ViewBag.DataSource
                </div>

                <!-- Warning Alert -->
                <div class="alert alert-warning" role="alert">
                    <i class="fas fa-exclamation-triangle"></i>
                    <strong>Warning!</strong> This action cannot be undone. Are you sure you want to delete this vehicle?
                </div>

                <!-- Vehicle Details -->
                <div class="detail-section">
                    <div class="detail-label">Vehicle ID</div>
                    <div class="detail-value">#@Model.Id</div>
                </div>

                <div class="detail-section">
                    <div class="detail-label">Make</div>
                    <div class="detail-value">@Model.Make</div>
                </div>

                <div class="detail-section">
                    <div class="detail-label">Year</div>
                    <div class="detail-value">@Model.Year</div>
                </div>

                <div class="detail-section">
                    <div class="detail-label">Color</div>
                    <div class="detail-value">@Model.Color</div>
                </div>

                <div class="detail-section">
                    <div class="detail-label">Type</div>
                    <div class="detail-value">@Model.Type.ToUpper()</div>
                </div>

                <!-- Action Buttons -->
                <div class="d-flex gap-2 justify-content-between mt-4">
                    <a href="@Url.Action("Index", "Vehicles")" class="btn btn-secondary">
                        <i class="fas fa-times"></i> Cancel
                    </a>
                    <form method="post" style="display: inline;">
                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-trash"></i> Yes, Delete Vehicle
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
